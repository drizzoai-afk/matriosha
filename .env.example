# ================================================================
# Matriosha local environment template (safe-to-commit example)
# ================================================================
# What this file is for:
# - This is a copy/paste template for local development configuration.
# - Fill values in a local `.env` file (do NOT commit `.env`).
# - In production, keep secrets in Google Secret Manager (GSM), not in `.env`.
#
# Quick start:
# 1) cp .env.example .env
# 2) edit .env and replace all EXAMPLE_* values
# 3) run your local backend/tests
#
# Local vs Production:
# - Local development: use `.env` for convenience
# - Production/staging: use GSM secrets + GCP_PROJECT_ID
# - Switching: remove local secret values and let runtime resolve from GSM

# ================================================================
# Google Cloud / GSM
# ================================================================
# Google Cloud project ID that contains your GSM secrets.
# Where to get it: Google Cloud Console -> project picker -> Project ID column.
GCP_PROJECT_ID=your-gcp-project-id

# ================================================================
# Supabase (Managed backend)
# ================================================================
# Base URL of your Supabase project.
# Where to get it: Supabase Dashboard -> Settings -> API -> Project URL.
MATRIOSHA_MANAGED_ENDPOINT=https://your-project-ref.supabase.co

# Supabase Service Role key (server-side only, highly sensitive).
# Where to get it: Supabase Dashboard -> Settings -> API -> service_role key.
MATRIOSHA_MANAGED_TOKEN=EXAMPLE_SUPABASE_SERVICE_ROLE_KEY

# Supabase JWT secret used to verify tokens.
# Where to get it: Supabase Dashboard -> Settings -> API -> JWT Secret.
SUPABASE_JWT_SECRET=EXAMPLE_SUPABASE_JWT_SECRET

# ================================================================
# Stripe (Billing)
# ================================================================
# Stripe Secret Key for server-side API access.
# Where to get it: Stripe Dashboard -> Developers -> API keys -> Secret key.
STRIPE_SECRET_KEY=sk_test_example1234567890

# Stripe webhook signing secret for event verification.
# Where to get it: Stripe Dashboard -> Developers -> Webhooks -> Signing secret.
STRIPE_WEBHOOK_SECRET=whsec_example1234567890

# ================================================================
# Usage reminders
# ================================================================
# - Keep `.env.example` as template only (placeholder values).
# - Put real values in local `.env` only.
# - For deployed environments, store real values in GSM and grant runtime access.
