 <Para 
  <Unique 287840>
  <PgfTag `1Heading'>
  <PgfNumString `4.0\t'>
  <ParaLine 
   <String `Packaging'>
  >
 > # end of Para
 <Para 
  <Unique 287222>
  <PgfTag `2Heading'>
  <PgfNumString `\t4.1\t'>
  <ParaLine 
   <String `Components'>
  >
 > # end of Para
 <Para 
  <Unique 287230>
  <PgfTag `FirstBody'>
  <ParaLine 
   <String `The WriterStation product consists of three main pieces:'>
  >
 > # end of Para
 <Para 
  <Unique 287231>
  <PgfTag `Bullet'>
  <PgfNumString `\xa5 \t'>
  <ParaLine 
   <String `The WriterStation editor (provided with every installation)'>
  >
 > # end of Para
 <Para 
  <Unique 287232>
  <PgfTag `Bullet'>
  <PgfNumString `\xa5 \t'>
  <ParaLine 
   <String `The application development environment (zero or one per site)'>
  >
 > # end of Para
 <Para 
  <Unique 287233>
  <PgfTag `Bullet'>
  <PgfNumString `\xa5 \t'>
  <ParaLine 
   <String `The DLEDT VAX/VMS host connection software (not required by every installa'>
   <Char SoftHyphen>
  >
  <ParaLine 
   <String `tion)'>
  >
 > # end of Para
 <Para 
  <Unique 287234>
  <PgfTag `Body'>
  <ParaLine 
   <TextRectID 27>
   <String `Each of these pieces is sold separately. Hypertext anchor here \>'>
   <Marker 
    <MType 8>
    <MText `newlink SoldSep'>
    <MCurrPage `4'>
    <Unique 288317>
   > # end of Marker
   <String `<. The DLEDT software '>
  >
  <ParaLine 
   <String `has both client and server components. '>
  >
 > # end of Para
 <Para 
  <Unique 287223>
  <PgfTag `2Heading'>
  <PgfNumString `\t4.2\t'>
  <ParaLine 
   <String `Documentation'>
  >
 > # end of Para
 <Para 
  <Unique 287354>
  <PgfTag `FirstBody'>
  <ParaLine 
   <String `There are some 20 manuals for WriterStation. The most important include a User '>
  >
  <ParaLine 
   <String `Guide, install guides for DLEDT, various manuals relating to the development of appli'>
   <Char SoftHyphen>
  >
  <ParaLine 
   <String `cations.'>
  >
 > # end of Para
 <Para 
  <Unique 287239>
  <PgfTag `1Heading'>
  <PgfNumString `5.0\t'>
  <ParaLine 
   <String `Target Markets'>
  >
 > # end of Para
 <Para 
  <Unique 284852>
  <PgfTag `FirstBody'>
  <ParaLine 
   <String `WriterStation is primarily targeted at two markets:'>
  >
 > # end of Para
 <Para 
  <Unique 286565>
  <PgfTag `Bullet'>
  <PgfNumString `\xa5 \t'>
  <ParaLine 
   <String `General SGML editing'>
  >
 > # end of Para
 <Para 
  <Unique 286844>
  <PgfTag `Bullet'>
  <PgfNumString `\xa5 \t'>
  <ParaLine 
   <String `Authoring for general SGML systems integration'>
  >
 > # end of Para
 <Para 
  <Unique 286868>
  <PgfTag `Body'>
  <ParaLine 
   <String `WriterStation is explicitly NOT a WYSIWYG editor. '>
  >
 > # end of Para
 <Para 
  <Unique 286863>
  <PgfTag `2Heading'>
  <PgfNumString `\t5.1\t'>
  <ParaLine 
   <String `Types of users'>
  >
 > # end of Para
 <Para 
  <Unique 284523>
  <PgfTag `FirstBody'>
  <ParaLine 
   <String `There are two groups of users for the product:'>
   <String ` '>
   <String `authors / editors, and application develop'>
   <Char SoftHyphen>
  >
  <ParaLine 
   <String `ers.'>
  >
 > # end of Para
 <Para 
  <Unique 286619>
  <PgfTag `Body'>
  <ParaLine 
   <Font 
    <FTag `Run-In Heading'>
    <FLocked No>
   > # end of Font
   <String `Authors (char format)/ editors'>
   <Font 
    <FTag `'>
    <FLocked No>
   > # end of Font
   <String ` use the WriterStation user interface to enter or modify '>
  >
  <ParaLine 
   <String `text documents or document fragments. They must be familiar with the details of the '>
  >
  <ParaLine 
   <String `user interface, and its concepts and facilities. Because WriterStation is not a WYSI'>
   <Char SoftHyphen>
  >
  <ParaLine 
   <String `WYG editor, users are not concerned with the formatting of the final output.'>
  >
 > # end of Para
 <Para 
  <Unique 284376>
  <PgfTag `Body'>
  <ParaLine 
   <Font 
    <FTag `'>
    <FPlatformName `W.Times New Roman.R.700'>
    <FWeight `Bold'>
    <FLocked No>
   > # end of Font
   <String `Application '>
   <String `(ad-hoc formatting) '>
   <String `developers'>
   <Font 
    <FTag `'>
    <FLocked No>
   > # end of Font
   <String ` are responsible for planning, designing, '>
  >
  <ParaLine 
   <String `and coding the WriterStation application. WriterStation cannot be used without an '>
  >
  <ParaLine 
   <String `application. '>
  >
 > # end of Para
 <Para 
  <Unique 281735>
  <PgfTag `1Heading'>
  <PgfNumString `6.0\t'>
  <ParaLine 
   <Marker 
    <MType 9>
    <MText `14473: 1Heading: 4.0 Product Requirements'>
    <MCurrPage `4'>
    <Unique 281651>
   > # end of Marker
   <String `1995 Product Requirements'>
  >
 > # end of Para
 <Para 
  <Unique 281712>
  <PgfTag `2Heading'>
  <PgfNumString `\t6.1\t'>
  <ParaLine 
   <String `General Requirements'>
  >
 > # end of Para
 <Para 
  <Unique 286727>
  <PgfTag `RuninHead'>
  <Pgf 
   <PgfNumTabs 1>
   <TabStop 
    <TSX  1.875">
    <TSType Right>
    <TSLeaderStr ` '>
   > # end of TabStop
  > # end of Pgf
  <ParaLine 
   <String `More (run-in para format) platforms.'>
  >
 > # end of Para
 <Para 
  <Unique 286954>
  <PgfTag `RuninHead'>
  <Pgf 
   <PgfSpBefore  13.0 pt>
   <PgfFont 
    <FTag `'>
    <FPlatformName `W.Times New Roman.R.400'>
    <FFamily `Times New Roman'>
    <FVar `Regular'>
    <FWeight `Regular'>
    <FAngle `Regular'>
    <FSize  10.0 pt>
    <FUnderlining FNoUnderlining>
    <FOverline No>
    <FStrike No>
    <FChangeBar No>
    <FOutline No>
    <FShadow No>
    <FPairKern Yes>
    <FCase FAsTyped>
    <FPosition FNormal>
    <FDX  0.0%>
    <FDY  0.0%>
    <FDW  0.0%>
    <FLocked No>
    <FSeparation 0>
    <FColor `Black'>
   > # end of PgfFont
   <PgfNumTabs 1>
   <TabStop 
    <TSX  1.875">
    <TSType Right>
    <TSLeaderStr ` '>
   > # end of TabStop
  > # end of Pgf
  <ParaLine 
   <String `WriterStation is currently in use at customer '>
  >
  <ParaLine 
   <String `sites on IBM PC\xd5 s running either OS/2 or DOS (character mode). The DOS character '>
  >
  <ParaLine 
   <String `mode version of WriterStation is antiquated and no longer acceptable for most users. '>
  >
  <ParaLine 
   <String `The OS/2 version of WriterStation, while robust and quite useful, is not on the operating '>
  >
  <ParaLine 
   <String `system which most users wish to use. '>
  >
 > # end of Para
 <Para 
  <Unique 286958>
  <PgfTag `FirstBody'>
  <ParaLine 
  >
 > # end of Para
 <Para 
  <Unique 286959>
  <PgfTag `RuninHead'>
  <ParaLine 
   <String `Application (run-in para format) Development Tools.'>
  >
 > # end of Para
 <Para 
  <Unique 286732>
  <PgfTag `Body'>
  <ParaLine 
   <String `There are two methods avail'>
   <Char SoftHyphen>
  >
  <ParaLine 
   <String `able for the creation of WriterStation applications. Application developers may either:'>
  >
 > # end of Para
 <Para 
  <Unique 286970>
  <PgfTag `Bullet'>
  <PgfNumString `\xa5 \t'>
  <ParaLine 
   <String `Hand-code the application. This requires the use of approximately four separate and '>
  >
  <ParaLine 
   <String `obscure languages, each of which addresses one of the customizable features of '>
  >
  <ParaLine 
   <String `WriterStation. This method is not satisfactory for most users of the product. '>
  >
 > # end of Para
 <Para 
  <Unique 286971>
  <PgfTag `Bullet'>
  <PgfNumString `\xa5 \t'>
  <ParaLine 
   <TextRectID 28>
   <String `Use WriterStation Tools. This is a point and click user interface which can be used '>
  >
  <ParaLine 
   <String `to create WriterStation applications. It was designed and built on OS/2, and while it '>
  >
  <ParaLine 
   <String `is available there, it has not been ported to Windows. '>
  >
 > # end of Para
 <Para 
  <Unique 286753>
  <PgfTag `2Heading'>
  <PgfNumString `\t6.2\t'>
  <ParaLine 
   <String `New Features'>
  >
 > # end of Para
 <Para 
  <Unique 282725>
  <PgfTag `FirstBody'>
  <ParaLine 
   <String `The following is a listing and description of the feature enhancements '>
   <String `desired f'>
   <String `or the '>
  >
  <ParaLine 
   <String `1995 product. With each feature is an indication of the vertical segment for which it is '>
  >
  <ParaLine 
   <String `required, and its priority. (1 is highest priority'>
   <String `-required,'>
   <String ` and 5 is lowest.).'>
   <ATbl 3>
  >
 > # end of Para
 <Para 
  <Unique 282772>
  <PgfTag `1Heading'>
  <PgfNumString `7.0\t'>
  <ParaLine 
   <String `Documentation'>
  >
 > # end of Para
 <Para 
  <Unique 283167>
  <PgfTag `Body'>
  <ParaLine 
   <String `No major changes to the documentation are proposed for this release. '>
  >
 > # end of Para
 <Para 
  <Unique 287632>
