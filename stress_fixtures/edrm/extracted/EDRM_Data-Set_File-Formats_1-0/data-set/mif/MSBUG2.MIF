  <ParaLine 
   <String `Current pricing for WS is dependent on the number of copies according to the following '>
  >
  <ParaLine 
   <String `model'>
   <Font 
    <FTag `'>
    <FSize  12.0 pt>
    <FPairKern No>
    <FLocked No>
   > # end of Font
