 <Para 
  <Unique 421744>
  <PgfTag `ChapterTitle'>
  <PgfReferenced Yes>
  <ParaLine 
   <TextRectID 25>
   <String `New Release Process'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 438135>
  <PgfTag `ChapterNumber'>
  <PgfNumString `1'>
  <PgfReferenced Yes>
  <ParaLine 
   <Char Tab>
   <Char Tab>
   <Char Tab>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470357>
  <PgfTag `Heading1'>
  <PgfNumString `1.1  '>
  <ParaLine 
   <String `Pre-Release Work '>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470389>
  <PgfTag `Body'>
  <ParaLine 
   <String `The following tasks can be completed at your desktop if you have the proper tools and '>
  > # end of ParaLine
  <ParaLine 
   <String `Lotus Notes access rights. In any situation where you lack any of these tools or access '>
  > # end of ParaLine
  <ParaLine 
   <String `rights, you can always use the main OEM Delivery System machine (located near Phil '>
  > # end of ParaLine
  <ParaLine 
   <String `Boutros\xd5  office) to perform the following tasks.'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470699>
  <PgfTag `Heading2'>
  <PgfNumString `1.1.1 '>
  <ParaLine 
   <String `Customer Status Verification'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470400>
  <PgfTag `Body'>
  <ParaLine 
   <String `Verify that all OEMs in the system still have valid licenses. '>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470629>
  <PgfTag `NumberedFirst'>
  <PgfNumString `\t1\t'>
  <ParaLine 
   <String `Finance should be able to provide a list of all inactive OEM accounts. If '>
  > # end of ParaLine
  <ParaLine 
   <String `finance cannot provide the list, ask sales if they have a list of inactive '>
  > # end of ParaLine
  <ParaLine 
   <String `OEMs.'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470649>
  <PgfTag `Numbered'>
  <PgfNumString `\t2\t'>
  <ParaLine 
   <String `Once you have obtained the list, enter the OEM Delivery system by '>
  > # end of ParaLine
  <ParaLine 
   <String `double-clicking the OEM Delivery System icon on your Notes desktop.'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470653>
  <PgfTag `Numbered'>
  <PgfNumString `\t3\t'>
  <ParaLine 
   <String `Click '>
   <Font 
    <FTag `'>
    <FPlatformName `W.Times New Roman.R.700'>
    <FWeight `Bold'>
    <FEncoding `FrameRoman'>
    <FLocked No>
   > # end of Font
   <String `OEMs'>
   <Font 
    <FTag `'>
    <FLocked No>
   > # end of Font
   <String ` in the view menu on the left. '>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470655>
  <PgfTag `Numbered'>
  <PgfNumString `\t4\t'>
  <ParaLine 
   <String `Find each inactive OEM from the list in the Notes database. Double-click '>
  > # end of ParaLine
  <ParaLine 
   <String `their name to view their profile. '>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470659>
  <PgfTag `Numbered'>
  <PgfNumString `\t5\t'>
  <ParaLine 
   <String `Double-click the \xd2 Inactive:\xd3  field and a drop-down menu will appear. '>
  > # end of ParaLine
  <ParaLine 
   <String `Click the menau\xd5 s arrow button, select \xd2 Yes\xd3  in the menu that appears, '>
  > # end of ParaLine
  <ParaLine 
   <String `click '>
   <Font 
    <FTag `'>
    <FPlatformName `W.Times New Roman.R.700'>
    <FWeight `Bold'>
    <FEncoding `FrameRoman'>
    <FLocked No>
   > # end of Font
   <String `OK'>
   <Font 
    <FTag `'>
    <FLocked No>
   > # end of Font
   <String `, and then click '>
   <Font 
    <FTag `'>
    <FPlatformName `W.Times New Roman.R.700'>
    <FWeight `Bold'>
    <FEncoding `FrameRoman'>
    <FLocked No>
   > # end of Font
   <String `Close'>
   <Font 
    <FTag `'>
    <FLocked No>
   > # end of Font
   <String `. When Notes asks if you want to save the '>
  > # end of ParaLine
  <ParaLine 
   <String `document, click '>
   <Font 
    <FTag `'>
    <FPlatformName `W.Times New Roman.R.700'>
    <FWeight `Bold'>
    <FEncoding `FrameRoman'>
    <FLocked No>
   > # end of Font
   <String `Yes'>
   <Font 
    <FTag `'>
    <FLocked No>
   > # end of Font
   <String `.'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470660>
  <PgfTag `Numbered'>
  <PgfNumString `\t6\t'>
  <ParaLine 
   <String `Repeat steps 4 and 5 for each inactive OEM on the list. '>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470406>
  <PgfTag `Heading2'>
  <PgfNumString `1.1.2 '>
  <ParaLine 
   <TextRectID 26>
   <String `Server Space Verification'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470407>
  <PgfTag `Body'>
  <ParaLine 
   <String `Ensure that there is enough space on the server\xd5 s d: drive for the new files related to the '>
  > # end of ParaLine
  <ParaLine 
   <String `impending release. An average release requires a minimum of 20GB of server space. If '>
  > # end of ParaLine
  <ParaLine 
   <String `more space is needed than currently exists, you can delete older releases beginning with '>
  > # end of ParaLine
  <ParaLine 
   <String `the previous release by marking them inactive in their profiles and then clicking the '>
  > # end of ParaLine
  <ParaLine 
   <Font 
    <FTag `'>
    <FPlatformName `W.Times New Roman.R.700'>
    <FWeight `Bold'>
    <FEncoding `FrameRoman'>
    <FLocked No>
   > # end of Font
   <String `Delete builds'>
   <Font 
    <FTag `'>
    <FLocked No>
   > # end of Font
   <String ` button. '>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470682>
  <PgfTag `Note'>
  <ParaLine 
   <String `Before marking releases as inactive or deleting builds, check the product '>
  > # end of ParaLine
  <ParaLine 
   <String `requirements document for the new release to make sure that the older releases you '>
  > # end of ParaLine
  <ParaLine 
   <String `intend to delete aren\xd5 t dependencies of your new release (i.e. an 8.1 release might '>
  > # end of ParaLine
  <ParaLine 
   <String `require that the 8.0 releases remain active).'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470415>
  <PgfTag `Heading2'>
  <PgfNumString `1.1.3 '>
  <ParaLine 
   <String `Release Creation'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470421>
  <PgfTag `NumberedFirst'>
  <PgfNumString `\t1\t'>
  <ParaLine 
   <String `In Lotus Notes, enter the OEM Delivery system by double-clicking the '>
  > # end of ParaLine
  <ParaLine 
   <String `OEM Delivery System icon on your Notes desktop.'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470539>
  <PgfTag `Numbered'>
  <PgfNumString `\t2\t'>
  <ParaLine 
   <String `Before you create a profile for a new release, first find the previous release '>
  > # end of ParaLine
  <ParaLine 
   <String `for the product and open its profile. Once the profile is open, minimize it.'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470366>
  <PgfTag `Numbered'>
  <PgfNumString `\t3\t'>
  <ParaLine 
   <String `Create a new release profile by clicking '>
   <Font 
    <FTag `'>
    <FPlatformName `W.Times New Roman.R.700'>
    <FWeight `Bold'>
    <FEncoding `FrameRoman'>
    <FLocked No>
   > # end of Font
   <String `Release'>
   <Font 
    <FTag `'>
    <FLocked No>
   > # end of Font
   <String ` in the '>
   <Font 
    <FTag `'>
    <FPlatformName `W.Times New Roman.R.700'>
    <FWeight `Bold'>
    <FEncoding `FrameRoman'>
    <FLocked No>
   > # end of Font
   <String `Create'>
   <Font 
    <FTag `'>
    <FLocked No>
   > # end of Font
   <String ` menu. '>
  > # end of ParaLine
  <ParaLine 
   <String `Minimize the new profile when it appears.'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470367>
  <PgfTag `Numbered'>
  <PgfNumString `\t4\t'>
  <ParaLine 
   <String `With both the prior release profile and the new release profile open, copy '>
  > # end of ParaLine
  <ParaLine 
   <String `all fields from the prior release profile to the new release profile.'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470554>
  <PgfTag `Numbered'>
  <PgfNumString `\t5\t'>
  <ParaLine 
   <String `Once you\xd5 ve finished copying the fields from the older prfile to the newer, '>
  > # end of ParaLine
  <ParaLine 
   <String `close the prior profile and maximize the new profile'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470555>
  <PgfTag `Numbered'>
  <PgfNumString `\t6\t'>
  <ParaLine 
   <String `Edit the new profile to add information specific to the new release.'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470557>
  <PgfTag `Bullet'>
  <Pgf 
   <PgfFIndent  114.0002 pt>
   <PgfLIndent  132.2502 pt>
   <PgfNumTabs 1>
   <TabStop 
    <TSX  132.2502 pt>
    <TSType Left>
    <TSLeaderStr ` '>
   > # end of TabStop
  > # end of Pgf
  <PgfNumString `\xa5 \t'>
  <ParaLine 
   <String `The path name should always begin with \xd2 d:\\webdel\\release\\\xd3  and end '>
  > # end of ParaLine
  <ParaLine 
   <String `with a directory name that reflects the new release (e.g. if the new '>
  > # end of ParaLine
  <ParaLine 
   <String `release is for Outside In 7.0 for the DEC UNIX platform, '>
  > # end of ParaLine
  <ParaLine 
   <TextRectID 27>
   <String `\xd2 d:\\webdel\\release\\ois70dec\\\xd3  would be an appropriate path). The path '>
  > # end of ParaLine
  <ParaLine 
   <String `must end with an \xd2 \\\xd3 . Write this path name down for future reference.'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470579>
  <PgfTag `Bullet'>
  <Pgf 
   <PgfFIndent  114.0002 pt>
   <PgfLIndent  132.2502 pt>
   <PgfNumTabs 1>
   <TabStop 
    <TSX  132.2502 pt>
    <TSType Left>
    <TSLeaderStr ` '>
   > # end of TabStop
  > # end of Pgf
  <PgfNumString `\xa5 \t'>
  <ParaLine 
   <String `The release ID should be replaced with a release ID identical to the end '>
  > # end of ParaLine
  <ParaLine 
   <String `directory in the path name (in the example above, \xd2 ois70dec\xd3 ).'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470582>
  <PgfTag `Bullet'>
  <Pgf 
   <PgfFIndent  114.0002 pt>
   <PgfLIndent  132.2502 pt>
   <PgfNumTabs 1>
   <TabStop 
    <TSX  132.2502 pt>
    <TSType Left>
    <TSLeaderStr ` '>
   > # end of TabStop
  > # end of Pgf
  <PgfNumString `\xa5 \t'>
  <ParaLine 
   <String `The short and long descriptions should be updated with new release '>
  > # end of ParaLine
  <ParaLine 
   <String `information (if you copied over information that read \xd2 Outside In 7.0 '>
  > # end of ParaLine
  <ParaLine 
   <String `for DEC UNIX,\xd3  change it to read \xd2 Outside In 7.1 for DEC UNIX\xd3 ).'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470583>
  <PgfTag `Bullet'>
  <Pgf 
   <PgfFIndent  114.0002 pt>
   <PgfLIndent  132.2502 pt>
   <PgfNumTabs 1>
   <TabStop 
    <TSX  132.2502 pt>
    <TSType Left>
    <TSLeaderStr ` '>
   > # end of TabStop
  > # end of Pgf
  <PgfNumString `\xa5 \t'>
  <ParaLine 
   <String `Change the release date field to today\xd5 s date or a date near the actual '>
  > # end of ParaLine
  <ParaLine 
   <String `release, if possible.'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470587>
  <PgfTag `Numbered'>
  <PgfNumString `\t7\t'>
  <ParaLine 
   <String `Click '>
   <Font 
    <FTag `'>
    <FPlatformName `W.Times New Roman.R.700'>
    <FWeight `Bold'>
    <FEncoding `FrameRoman'>
    <FLocked No>
   > # end of Font
   <String `Close'>
   <Font 
    <FTag `'>
    <FLocked No>
   > # end of Font
   <String `. Notes will ask if you want to save the new document. Click '>
  > # end of ParaLine
  <ParaLine 
   <Font 
    <FTag `'>
    <FPlatformName `W.Times New Roman.R.700'>
    <FWeight `Bold'>
    <FEncoding `FrameRoman'>
    <FLocked No>
   > # end of Font
   <String `Yes'>
   <Font 
    <FTag `'>
    <FLocked No>
   > # end of Font
   <String `.'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470597>
  <PgfTag `Numbered'>
  <PgfNumString `\t8\t'>
  <ParaLine 
   <String `Open Windows Explorer and create the path that you indicated in the \xd2 Path '>
  > # end of ParaLine
  <ParaLine 
   <String `to release:\xd3  field in the new profile.'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470598>
  <PgfTag `Numbered'>
  <PgfNumString `\t9\t'>
  <ParaLine 
   <String `Repeat steps 1 through 8 for each new product/platfrom combination in '>
  > # end of ParaLine
  <ParaLine 
   <String `that is part of the new release.'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470599>
  <PgfTag `Numbered'>
  <PgfNumString `\t10\t'>
  <ParaLine 
   <String `When you\xd5 ve created new profiles for each product/platform combination '>
  > # end of ParaLine
  <ParaLine 
   <String `for the release, send an email to engineering telling them what the new '>
  > # end of ParaLine
  <ParaLine 
   <String `directories are for each release profile so that they know where to place the '>
  > # end of ParaLine
  <ParaLine 
   <String `binary files for the release.'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470702>
  <PgfTag `Heading2'>
  <PgfNumString `1.1.4 '>
  <ParaLine 
   <String `Create Filter Modules'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470706>
  <PgfTag `NumberedFirst'>
  <PgfNumString `\t1\t'>
  <ParaLine 
   <String `Create a new module for each new filter. Each module should have a '>
  > # end of ParaLine
  <ParaLine 
   <String `different name for each platform-specific version. Make sure you create '>
  > # end of ParaLine
  <ParaLine 
   <String `modules for all possible combinations of filter and platform.'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470710>
  <PgfTag `Numbered'>
  <PgfNumString `\t2\t'>
  <ParaLine 
   <String `Add the new filters to the relevant groups. Add new premier graphics or '>
  > # end of ParaLine
  <ParaLine 
   <String `international formats to the appropriate groups and add any new modules to '>
  > # end of ParaLine
  <ParaLine 
   <String `all \xd2 Exclude after x\xd3  groups.'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470714>
  <PgfTag `Numbered'>
  <PgfNumString `\t3\t'>
  <ParaLine 
   <TextRectID 28>
   <String `Create a new exclude group to cover filters new to this release. For '>
  > # end of ParaLine
  <ParaLine 
   <String `example, if you\xd5 re releasing version 7.0 and the prior release was version '>
  > # end of ParaLine
  <ParaLine 
   <String `6.5, create a \xd2 Exclude_All_New_After_65\xd3  group and add the module '>
  > # end of ParaLine
  <ParaLine 
   <String `name for each new filter in 7.0.'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470715>
  <PgfTag `Heading2'>
  <PgfNumString `1.1.5 '>
  <ParaLine 
   <String `Create .zip Files for All Supplementary Downloads'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470719>
  <PgfTag `Body'>
  <ParaLine 
   <String `Create .zip files for the final versions of the following:'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470723>
  <PgfTag `Bullet'>
  <PgfNumString `\xa5 \t'>
  <ParaLine 
   <String `Release notes for each product'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470748>
  <PgfTag `Bullet'>
  <PgfNumString `\xa5 \t'>
  <ParaLine 
   <String `Format lists for each product'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470749>
  <PgfTag `Bullet'>
  <PgfNumString `\xa5 \t'>
  <ParaLine 
   <String `Documentation for each product'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470754>
  <PgfTag `Body'>
  <ParaLine 
   <String `Place all of these .zip files in the root level of webdelivery/general.'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470775>
  <PgfTag `Heading2'>
  <PgfNumString `1.1.6 '>
  <ParaLine 
   <String `Create New General Downloads Sections for Each '>
  > # end of ParaLine
  <ParaLine 
   <String `Product/Platform'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470779>
  <PgfTag `NumberedFirst'>
  <PgfNumString `\t1\t'>
  <ParaLine 
   <String `Create new entries for the new release notes, format lists, and '>
  > # end of ParaLine
  <ParaLine 
   <String `documenatation.'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470780>
  <PgfTag `Numbered'>
  <PgfNumString `\t2\t'>
  <ParaLine 
   <String `Create an entry for Common Components (same for all platforms)'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470781>
  <PgfTag `Numbered'>
  <PgfNumString `\t3\t'>
  <ParaLine 
   <String `Create an entry for the SDK for each platform'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470782>
  <PgfTag `Body'>
  <ParaLine 
   <String `All file names must be 8 characters or less and all must be .zip or .tar files. Share the file '>
  > # end of ParaLine
  <ParaLine 
   <String `names you create with engineering for that the SDKs and common component files can '>
  > # end of ParaLine
  <ParaLine 
   <String `be named accordingly.'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470791>
  <PgfTag `Heading1'>
  <PgfNumString `1.2  '>
  <ParaLine 
   <String `Release Work'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470795>
  <PgfTag `Body'>
  <ParaLine 
   <String `The following tasks must be completed on the main OEM Delivery System machine '>
  > # end of ParaLine
  <ParaLine 
   <String `(located near Phil Boutros\xd5  office).'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470828>
  <PgfTag `Heading2'>
  <PgfNumString `1.2.1 '>
  <ParaLine 
   <TextRectID 29>
   <String `Build Releases'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470838>
  <PgfTag `Body'>
  <ParaLine 
   <String `After a release has been approved, engineering will run scripts that place the appropriate '>
  > # end of ParaLine
  <ParaLine 
   <String `binaries into the corresponding folders in the webdelivery/release directory on the OEM '>
  > # end of ParaLine
  <ParaLine 
   <String `delivery machine. '>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470861>
  <PgfTag `Note'>
  <ParaLine 
   <String `If you wish for certain filters to be excluded for specific OEMs, those files should NOT '>
  > # end of ParaLine
  <ParaLine 
   <String `be in .zip or .tar archives.'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470852>
  <PgfTag `Body'>
  <ParaLine 
   <String `Once engineering has communicated that the binaries are in the release folders, you can '>
  > # end of ParaLine
  <ParaLine 
   <String `enter the OEM delivery system and build the releases from within the release profiles by '>
  > # end of ParaLine
  <ParaLine 
   <String `clicking the \xd2 Build This Release\xd3  button. Repeat this step for each release.'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470865>
  <PgfTag `Body'>
  <ParaLine 
   <String `Engineering will also run scripts that place the product/platform specific SDKs and '>
  > # end of ParaLine
  <ParaLine 
   <String `common components in the root of webdelivery/general. These are built and ready for '>
  > # end of ParaLine
  <ParaLine 
   <String `download once engineering has completed running their scripts and require no further '>
  > # end of ParaLine
  <ParaLine 
   <String `work in the OEM delivery system to prepare them for release.'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470866>
  <PgfTag `Heading2'>
  <PgfNumString `1.2.2 '>
  <ParaLine 
   <String `Update the OEM Web Pages'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470870>
  <PgfTag `Body'>
  <ParaLine 
   <String `Once engineering completes a media verification to determine that the builds were '>
  > # end of ParaLine
  <ParaLine 
   <String `successfully completed, you can update the OEM Web pages in the OEM delivery '>
  > # end of ParaLine
  <ParaLine 
   <String `system. From each new release page, click the \xd2 Update Web Pages\xd3  button.'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470871>
  <PgfTag `Heading2'>
  <PgfNumString `1.2.3 '>
  <ParaLine 
   <String `Update the General Downloads Page'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470875>
  <PgfTag `Body'>
  <ParaLine 
   <String `From the \xd2 General Downloads\xd3  view within the OEM delivery system, click the '>
  > # end of ParaLine
  <ParaLine 
   <String `\xd2 Update General Downloads Page\xd3  button. '>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470876>
  <PgfTag `Note'>
  <ParaLine 
   <TextRectID 30>
   <String `The General Downloads section of the OEM delivery Web site is first updated on a '>
  > # end of ParaLine
  <ParaLine 
   <String `development site. It is not live on www.oi.intranetsolutions.com until it is '>
  > # end of ParaLine
  <ParaLine 
   <String `synchronized.'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470880>
  <PgfTag `Heading2'>
  <PgfNumString `1.2.4 '>
  <ParaLine 
   <String `Set Older Releases to Inactive'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470887>
  <PgfTag `Body'>
  <ParaLine 
   <String `At this point it is safe to set all releases you no longer wish to make available to inactive '>
  > # end of ParaLine
  <ParaLine 
   <String `by entering the release page for each product/platform from the prior version and '>
  > # end of ParaLine
  <ParaLine 
   <String `changing the \xd2 Active:\xd3  field to \xd2 No\xd3 . Create archive folders for the prior release in '>
  > # end of ParaLine
  <ParaLine 
   <String `webdelivery/release and move all folders from the old releases into these archive '>
  > # end of ParaLine
  <ParaLine 
   <String `folders.'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470888>
  <PgfTag `Heading2'>
  <PgfNumString `1.2.5 '>
  <ParaLine 
   <String `Remove Old SDKs'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470893>
  <PgfTag `Body'>
  <ParaLine 
   <String `Go to General Downloads and delete the old entries for each product/platform leaving '>
  > # end of ParaLine
  <ParaLine 
   <String `only those entries you wish to be visible on the General Downloads page. Move all '>
  > # end of ParaLine
  <ParaLine 
   <String `removed files from the root of webdelivery/general to the archive folder.'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470894>
  <PgfTag `Heading2'>
  <PgfNumString `1.2.6 '>
  <ParaLine 
   <String `Synchronize'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470899>
  <PgfTag `Body'>
  <ParaLine 
   <String `Now you are ready to synchronize the General Downloads page on the developement '>
  > # end of ParaLine
  <ParaLine 
   <String `site with the live OEM delivery site. Click the \xd2 Sync...\xd3  button. The live site is now '>
  > # end of ParaLine
  <ParaLine 
   <String `updated.'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470909>
  <PgfTag `Heading2'>
  <PgfNumString `1.2.7 '>
  <ParaLine 
   <String `Update the News Page'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470913>
  <PgfTag `Body'>
  <ParaLine 
   <String `Using an HTML editor, update the \xd2 news\xd3  page to reflect information pertinent to this '>
  > # end of ParaLine
  <ParaLine 
   <String `latest release.'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470916>
  <PgfTag `Heading2'>
  <PgfNumString `1.2.8 '>
  <ParaLine 
   <TextRectID 31>
   <String `Customer Notification'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470920>
  <PgfTag `Body'>
  <ParaLine 
   <String `OEMs can now be notified via email that a new release is available. The email should '>
  > # end of ParaLine
  <ParaLine 
   <String `include a list of all products that have been update to avoid multiple notifications being '>
  > # end of ParaLine
  <ParaLine 
   <String `sent to any OEMs that liscense multiple products. Once the email is created, select all '>
  > # end of ParaLine
  <ParaLine 
   <String `active OEMs from the \xd2 Active OEM\xd3  view and then click Action -\> Send Special Mail '>
  > # end of ParaLine
  <ParaLine 
   <String `for Selected OEMs.'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470922>
  <PgfTag `Heading2'>
  <PgfNumString `1.2.9 '>
  <ParaLine 
   <String `Prepare for Physical Delivery'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470923>
  <PgfTag `Body'>
  <ParaLine 
   <String `Once OEM web delivery is complete, instruct engineering to prepare new CD images '>
  > # end of ParaLine
  <ParaLine 
   <String `for evaluation CDs to be delivered to Ed Cruz. Update the BOMs and materials related '>
  > # end of ParaLine
  <ParaLine 
   <String `to physical delivery of the products, including manuals.'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470895>
  <PgfTag `Body'>
  <ParaLine 
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470889>
  <PgfTag `Body'>
  <ParaLine 
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470809>
  <PgfTag `Body'>
  <ParaLine 
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470807>
  <PgfTag `Body'>
  <ParaLine 
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 470806>
  <PgfTag `Body'>
  <ParaLine 
   <Char HardReturn>
  > # end of ParaLine
  <ParaLine 
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 425189>
  <PgfTag `Body'>
  <ParaLine 
  > # end of ParaLine
 > # end of Para
> # end of TextFlow
# End of MIFFile
