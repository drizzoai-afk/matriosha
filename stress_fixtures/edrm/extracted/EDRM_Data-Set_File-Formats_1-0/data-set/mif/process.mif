&\n
&		{\r
&\n
&		 end\r
&\n
&		} if\r
&\n
&	} bind def\r
&\n
&	mark\r
&\n
&	/setcustomcolor where not\r
&\n
&	{\r
&\n
&		/findcmykcustomcolor\r
&\n
&		{\r
&\n
&			(AI8_CMYK_CustomColor)\r
&\n
&			6 packedarray\r
&\n
&		} bind def\r
&\n
&		/findrgbcustomcolor\r
&\n
&		{\r
&\n
&			(AI8_RGB_CustomColor)\r
&\n
&			5 packedarray\r
&\n
&		} bind def\r
&\n
&		/setcustomcolor\r
&\n
&		{\r
&\n
&			exch \r
&\n
&			aload pop dup\r
&\n
&			(AI8_CMYK_CustomColor) eq\r
&\n
&			{\r
&\n
&				pop pop\r
&\n
&				4\r
&\n
&				{\r
&\n
&					4 index mul\r
&\n
&					4 1 roll\r
&\n
&				} repeat\r
&\n
&				5 -1 roll pop\r
&\n
&				setcmykcolor\r
&\n
&			}\r
&\n
&			{\r
&\n
&				dup (AI8_RGB_CustomColor) eq\r
&\n
&				{\r
&\n
&					pop pop\r
&\n
&					3\r
&\n
&					{\r
&\n
&						1 exch sub\r
&\n
&						3 index mul \r
&\n
&						1 exch sub\r
&\n
&						3 1 roll\r
&\n
&					} repeat\r
&\n
&					4 -1 roll pop\r
&\n
&					setrgbcolor\r
&\n
