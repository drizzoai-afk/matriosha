&userdict /Adobe_level2_AI5 26 dict dup begin\r
&\n
&	put\r
&\n
&	/packedarray where not\r
&\n
&	{\r
&\n
&		userdict begin\r
&\n
&		/packedarray\r
&\n
&		{\r
&\n
&			array astore readonly\r
&\n
&		} bind def\r
&\n
&		/setpacking /pop load def\r
&\n
&		/currentpacking false def\r
&\n
&	 end\r
&\n
&		0\r
&\n
&	} if\r
&\n
&	pop\r
&\n
&	userdict /defaultpacking currentpacking put true setpacking\r
&\n
&	/initialize\r
&\n
&	{\r
&\n
&		Adobe_level2_AI5 begin\r
&\n
&	} bind def\r
&\n
&	/terminate\r
