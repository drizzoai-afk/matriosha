&} def\r
&\n
&/rdpatch168 {\r
&\n
&	/dataptr 0 store\r
&\n
&	49 rdcount\r
&\n
&	4 {\r
&\n
&		dup {pop srcchannels getint8} if\r
&\n
&		dup {pop srctodstcolor dstchannels putint8 true} if\r
&\n
&	} repeat\r
&\n
&	{databuf 0 dataptr getinterval}{()} ifelse\r
&\n
&} def\r
&\n
&/rdpatch3216 {\r
&\n
&	/dataptr 0 store\r
&\n
&	97 rdcount\r
&\n
&	4 {\r
&\n
&		dup {pop srcchannels getint16} if\r
&\n
&		dup {pop srctodstcolor dstchannels putint16 true} if\r
&\n
&	} repeat\r
&\n
&	{databuf 0 dataptr getinterval}{()} ifelse\r
&\n
&} def\r
&\n
&/rdcount {\r
&\n
&	dup 0 gt {\r
&\n
&		datafile databuf dataptr 4 -1 roll getinterval readstring\r
&\n
&		exch length dataptr add /dataptr exch store\r
&\n
&	}{\r
&\n
&		true\r
&\n
&	} ifelse\r
&\n
&} def\r
&\n
&/getint8 {\r
&\n
&	mark true 3 -1 roll\r
&\n
&	{\r
&\n
&		dup {pop datafile read} if\r
&\n
&		dup {pop 255 div true} if\r
&\n
&	} repeat\r
&\n
&	{\r
&\n
&		counttomark 1 add -1 roll pop true\r
&\n
&	}{\r
&\n
&		cleartomark false\r
&\n
&	} ifelse\r
&\n
&} def\r
&\n
&/putint8 {\r
&\n
&	dup dataptr add /dataptr exch store\r
&\n
&	dataptr exch\r
&\n
&	{\r
&\n
&		1 sub exch\r
&\n
&		255 mul cvi\r
&\n
&		databuf 2 index\r
&\n
&		3 -1 roll put\r
&\n
&	} repeat\r
&\n
&	pop\r
&\n
&} def \r
&\n
&/getint16 {\r
&\n
&	mark true 3 -1 roll\r
&\n
&	{\r
&\n
&		dup {pop datafile read} if\r
&\n
&		dup {pop 256 mul datafile read} if\r
&\n
&		dup {pop add 65535 div true} if\r
&\n
&	} repeat\r
&\n
&	{\r
&\n
&		counttomark 1 add -1 roll pop true\r
&\n
&	}{\r
&\n
&		cleartomark false\r
&\n
&	} ifelse\r
&\n
&} def\r
&\n
&/putint16 {\r
&\n
&	dup 2 mul dataptr add /dataptr exch store\r
&\n
&	dataptr exch\r
&\n
&	{\r
&\n
&		2 sub exch\r
&\n
&		65535 mul cvi dup\r
&\n
&		256 idiv databuf 3 index 3 -1 roll put\r
&\n
&		256 mod databuf 2 index 1 add 3 -1 roll put\r
&\n
&	} repeat\r
&\n
&	pop\r
&\n
&} def \r
&\n
&/srcbuf 256 string def\r
&\n
&/rdcmntline {\r
&\n
&	currentfile srcbuf readline pop\r
&\n
&	(%) anchorsearch {pop} if\r
&\n
&} def\r
&\n
&/getplateindex {\r
&\n
&	0 [cyan? magenta? yellow? black? customColor?] {{exit} if 1 add} forall\r
&\n
&} def\r
&\n
&/aicsarray 4 array def\r
&\n
&/aicsaltvals 4 array def\r
&\n
&/aicsaltcolr aicsaltvals def\r
&\n
&/tocolorspace {\r
&\n
&	dup type /arraytype eq {\r
&\n
&		mark exch aload pop\r
&\n
&		aicsarray 0 3 -1 roll put\r
&\n
&		aicsarray 1 3 -1 roll put\r
&\n
&		dup aicsarray 2 3 -1 roll put\r
&\n
&		gettintxform aicsarray 3 3 -1 roll put\r
&\n
&		counttomark aicsaltvals 0 3 -1 roll getinterval /aicsaltcolr exch store\r
&\n
&		aicsaltcolr astore pop pop\r
&\n
&		aicsarray\r
&\n
&	} if\r
&\n
&} def\r
&\n
&/subtintxform {aicsaltcolr {1 index mul exch} forall pop} def\r
&\n
&/addtintxform {aicsaltcolr {1 sub 1 index mul 1 add exch} forall pop} def\r
&\n
&/gettintxform {\r
&\n
&	/DeviceRGB eq {/addtintxform}{/subtintxform} ifelse load\r
&\n
&} def\r
&\n
&/getnchannels {\r
&\n
&	dup type /arraytype eq {0 get} if\r
&\n
&	colorspacedict exch get begin Channels end\r
&\n
&} def\r
&\n
&/makesmarks {\r
&\n
&	composite? {\r
&\n
&		pop true\r
&\n
&	}{\r
&\n
&		dup dup type /arraytype eq {0 get} if\r
&\n
&		colorspacedict exch get begin MarksPlate end\r
&\n
&	} ifelse\r
&\n
&} def\r
&\n
&/markingplate {\r
&\n
&	composite? {\r
&\n
&		pop true\r
&\n
&	}{\r
&\n
&		dup type /arraytype eq {\r
&\n
&			dup length getplateindex gt {getplateindex get}{pop false} ifelse\r
&\n
&		} if\r
&\n
&	} ifelse\r
&\n
&} def\r
&\n
&/tocmyk {\r
&\n
&	dup dup type /arraytype eq {0 get} if\r
&\n
&	colorspacedict exch get begin ToCMYK end\r
&\n
&} def\r
&\n
&/topsspace {\r
&\n
&	dup dup type /arraytype eq {0 get} if\r
&\n
&	colorspacedict exch get begin ToPSSpace end\r
&\n
&} def\r
&\n
&/colorspacedict 5 dict dup begin\r
&\n
&	/DeviceGray 4 dict dup begin\r
&\n
&		/Channels 1 def\r
&\n
&		/MarksPlate {pop black?} def\r
&\n
&		/ToCMYK {pop 1 exch sub 0 0 0 4 -1 roll} def\r
&\n
&		/ToPSSpace {} def\r
&\n
& end def\r
&\n
&	/DeviceRGB 4 dict dup begin\r
&\n
&		/Channels 3 def\r
&\n
&		/MarksPlate {pop isCMYKSep?} def\r
&\n
&		/ToCMYK {pop _rgbtocmyk} def\r
&\n
&		/ToPSSpace {} def\r
&\n
& end def\r
&\n
&	/DeviceCMYK 4 dict dup begin\r
&\n
&		/Channels 4 def\r
&\n
&		/MarksPlate {pop isCMYKSep?} def\r
&\n
&		/ToCMYK {pop} def\r
&\n
&		/ToPSSpace {} def\r
&\n
& end def\r
&\n
&	/Separation 4 dict dup begin\r
&\n
&		/Channels 1 def\r
&\n
&		/MarksPlate {\r
&\n
&			/findcmykcustomcolor where {\r
&\n
&				pop dup 1 exch ToCMYK 5 -1 roll 1 get\r
&\n
&				findcmykcustomcolor 1 setcustomcolor\r
&\n
&				systemdict /currentgray get exec\r
&\n
&				1 ne\r
&\n
&			}{\r
&\n
&				pop false\r
&\n
&			} ifelse\r
&\n
&		} def\r
&\n
&		/ToCMYK {\r
&\n
&			dup 2 get mark exch 4 2 roll\r
&\n
&			3 get exec\r
&\n
&			counttomark -1 roll tocmyk\r
&\n
&			5 -1 roll pop\r
&\n
&		} def\r
&\n
&		/ToPSSpace {} def\r
&\n
& end def\r
&\n
&	/Process 4 dict dup begin\r
&\n
&		/Channels 1 def\r
&\n
&		/MarksPlate {\r
&\n
&			isCMYKSep? {\r
&\n
&				1 exch ToCMYK 4 array astore getplateindex get 0 ne \r
&\n
&			}{\r
&\n
&				pop false\r
&\n
&			} ifelse\r
&\n
&		} def\r
&\n
&		/ToCMYK {\r
&\n
&			dup 2 get mark exch 4 2 roll\r
&\n
&			3 get exec\r
&\n
&			counttomark -1 roll tocmyk\r
&\n
&			5 -1 roll pop\r
&\n
&		} def\r
&\n
&		/ToPSSpace {\r
&\n
&			4 array copy dup 0 /Separation put\r
&\n
&		} def\r
&\n
& end def\r
&\n
&end def\r
&\n
&/isoverprint {\r
&\n
&	/currentoverprint where {pop currentoverprint}{_of} ifelse\r
&\n
&} def\r
