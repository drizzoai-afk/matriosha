currentpacking true setpacking
userdict /Adobe_cshow 12 dict dup begin put

% initialization and termination of the procSet (2 procs)

/initialize			% - initialize -
{
	Adobe_cshow begin
	Adobe_cshow
	{
		dup xcheck
