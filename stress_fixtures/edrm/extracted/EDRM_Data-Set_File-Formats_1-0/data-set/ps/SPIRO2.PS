%!
% spiro.ps
% Author: Phil Smith <pns@cs.nott.ac.uk>
% Plots the locus of a point on a circle as it rolls around
% the outside of an ellipse. Can take a while to print ;-)
% Tamper with this at your peril --- I can't remember how it works now!

/spirodict 50 dict def
/spiro {
    spirodict begin
    /astep 1 def
    /orad exch def
    /circ orad 2 mul 3.14159265 mul def
    /iyrad exch def
    /ixrad exch def
    /bqoaq iyrad 4 exp ixrad 4 exp div def
  % x,y for circle centre in relation to edge of ellipse
    /ox orad def
    /oy 0 def
  % angles round ellipse and circle
    /oang 0 def
    /iang 0 def
  % memory for points on ellipse
    /lastex ixrad def
    /lastey 0 def
    /tempx 0 def
    /tempy 0 def
    /dist 0 def
  % memory for plotted points
    /lastx ixrad orad 2 mul add def
    /lasty 0 def
    /startx lastx def
    /starty lasty def
    /firstloop true def
    gsave
    translate
    {
	newpath
	lastex lastey moveto
	ox oy rmoveto 
	orad oang cos mul orad oang sin mul rmoveto
	currentpoint 2 copy
	lastx lasty moveto
	lineto stroke

% Uncomment the line below to see things being plotted in GhostScript
%	flushpage

	/lasty exch def /lastx exch def
	lastx round startx eq lasty round starty eq and {
	    firstloop {
		/firstloop false def
	    } {
		exit
	    } ifelse
	} if
      % work out new angles and join point
	/iang iang astep add def
	/tempx iang cos ixrad mul def
	/tempy iang sin iyrad mul def
        /dist
	  lastex tempx sub dup mul
	  lastey tempy sub dup mul
	  add sqrt
	def
	/oang oang dist circ div 360 mul add def
	/lastex tempx def
	/lastey tempy def
      % lastex,lastey is join point
      % work out ox and oy
	lastey 0 eq {
	    /ox orad def
	    /oy 0 def
	} { 
	    /ysqd
	      orad 2 exp 
	      lastex 2 exp lastey 2 exp div bqoaq mul
	      1 add div
	    def
	    /oy ysqd sqrt def
	    /ox orad 2 exp ysqd sub sqrt def
	} ifelse
	lastex 0 lt {/ox 0 ox sub def} if
	lastey 0 lt {/oy 0 oy sub def} if
    } loop
    grestore
    end
} def

0 setlinewidth % speeds up plot in GhostScript

% Arguments to spiro are centre of ellipse, x and y radii of ellipse
% and radius of circle. Commented lines below also work quite nicely

%/ixrad 65 def
%/iyrad 67 def
%/orad 15 def

/ixrad 40 def
/iyrad 40 def
/orad 85 def

300 400 ixrad iyrad orad spiro


showpage

/ixrad 30 def
/iyrad 100 def
/orad 40 def

0 setlinewidth % speeds up plot in GhostScript

300 400 ixrad iyrad orad spiro

showpage
